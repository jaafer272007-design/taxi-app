# ─────────────────────────────────────────────────────────────
# Taxi API — environment (Phase 1)
# Copy to `.env` and fill in. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
# Iraq timezone — non-negotiable constant (see CLAUDE.md)
TZ=Asia/Baghdad

# Database — PostgreSQL (docker-compose uses postgis/postgis; PostGIS is
# available but unused in Phase 1, which stores plain lat/lng floats).
# Host port 5433 + DB name taxi_db match docker-compose.yml, which uses
# NON-default ports so this stack can run alongside another local stack (e.g.
# Aurora) without colliding. See docs/RUN_LOCAL.md.
DATABASE_URL="postgresql://taxi:taxi@localhost:5433/taxi_db?schema=public"

# Cache / OTP store — Redis (host port 6380, also non-default; see above).
REDIS_URL="redis://localhost:6380"

# Auth — JWT
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Admin seed — the ONE admin user created by `npm run prisma:seed`.
# Admin logs in via the normal WhatsApp OTP flow and gets an ADMIN-role JWT.
ADMIN_PHONE=+9647700000000

# Driver document uploads — local disk in dev.
# TODO(prod): swap to object storage (S3-compatible) before production.
UPLOAD_DIR=./uploads

# OTP policy
OTP_TTL_SECONDS=300           # how long a code stays valid (5 min)
OTP_LENGTH=6
OTP_RATE_LIMIT_MAX=3          # max request-otp per window, per phone
OTP_RATE_LIMIT_WINDOW_SECONDS=600   # window = 10 min
OTP_MAX_VERIFY_ATTEMPTS=5     # wrong-code attempts before a code is burned

# ─────────────────────────────────────────────────────────────
# WhatsApp Business Cloud API (OTP delivery)
# Reuse the Sehat Beitak setup. If ANY of the three vars below are
# missing, the API falls back to logging the OTP to the console
# (DEV-ONLY). That fallback is a HARD release blocker and is refused
# when NODE_ENV=production.
#
# LOCAL DEV (no WhatsApp yet): leave these three EMPTY. The server then
# prints the login code to its logs, e.g.:
#   [DEV-ONLY][RELEASE BLOCKER] WhatsApp not configured — OTP for +9647… is 123456.
# There is no separate OTP_DEV_LOG flag — "empty WhatsApp config" IS the switch.
# ─────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=ar
WHATSAPP_API_VERSION=v21.0

# ─────────────────────────────────────────────────────────────
# Push notifications — FCM (Firebase Admin SDK).
# If any of the three below are missing, notifications are logged to the
# console instead (DEV-ONLY — not a release blocker). Set all three in prod.
# FIREBASE_PRIVATE_KEY: paste the key with literal \n escapes (they're
# converted to real newlines at boot).
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
