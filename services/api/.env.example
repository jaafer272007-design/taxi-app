# ─────────────────────────────────────────────────────────────
# Taxi API — environment (Phase 1)
# Copy to `.env` and fill in. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
# Iraq timezone — non-negotiable constant (see CLAUDE.md)
TZ=Asia/Baghdad

# Database — PostgreSQL (docker-compose uses postgis/postgis; PostGIS is
# available but unused in Phase 1, which stores plain lat/lng floats).
DATABASE_URL="postgresql://taxi:taxi@localhost:5432/taxi_dev?schema=public"

# Cache / OTP store — Redis
REDIS_URL="redis://localhost:6379"

# Auth — JWT
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="30d"

# OTP policy
OTP_TTL_SECONDS=300           # how long a code stays valid (5 min)
OTP_LENGTH=6
OTP_RATE_LIMIT_MAX=3          # max request-otp per window, per phone
OTP_RATE_LIMIT_WINDOW_SECONDS=600   # window = 10 min
OTP_MAX_VERIFY_ATTEMPTS=5     # wrong-code attempts before a code is burned

# ─────────────────────────────────────────────────────────────
# WhatsApp Business Cloud API (OTP delivery)
# Reuse the Sehat Beitak setup. If ANY of the three vars below are
# missing, the API falls back to logging the OTP to the console
# (DEV-ONLY). That fallback is a HARD release blocker and is refused
# when NODE_ENV=production.
# ─────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=ar
WHATSAPP_API_VERSION=v21.0
